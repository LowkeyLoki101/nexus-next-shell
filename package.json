{
  "name": "nexus-next-shell",
  "version": "1.0.0",
  "description": "Nexus Next hybrid SHELL — the user-facing client (Electron + Web). Renders the UI and captures local devices; all agent/LLM work runs on the remote Nexus Next engine. Contains no engine source.",
  "license": "MIT",
  "type": "module",
  "main": "dist/electron/main.cjs",
  "scripts": {
    "dev:web": "vite",
    "build:web": "vite build",
    "build:electron": "node scripts/build-electron.mjs",
    "build": "npm run build:web && npm run build:electron",
    "smoke:web": "node scripts/smoke-web-shell.mjs",
    "start:electron": "electron dist/electron/main.cjs",
    "package:mac:dir": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dir --arm64",
    "package:mac": "npm run build && electron-builder --mac dmg zip --arm64",
    "typecheck": "tsc --noEmit",
    "capsule:verify": "node scripts/verify-capsule.mjs capsule/capsule.json capsule/public-key.pem"
  },
  "build": {
    "appId": "com.eig.nexus.next.capsule",
    "productName": "NEXUS Next Capsule",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json",
      "LICENSE"
    ],
    "asar": true,
    "afterSign": "scripts/notarize.cjs",
    "mac": {
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "target": [
        "dmg",
        "zip"
      ],
      "extendInfo": {
        "LSMinimumSystemVersion": "12.0",
        "NSCameraUsageDescription": "NEXUS Next Capsule uses the camera for optional gaze and vision features.",
        "NSMicrophoneUsageDescription": "NEXUS Next Capsule uses the microphone for optional voice features."
      }
    },
    "dmg": {
      "sign": false
    }
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@elevenlabs/react": "^1.0.0",
    "@mediapipe/tasks-vision": "^0.10.35",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "^33.2.1",
    "electron-builder": "^26.15.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.3",
    "vite": "^5.4.14"
  }
}
