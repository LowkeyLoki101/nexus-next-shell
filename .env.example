# Nexus Next Shell — environment (client-side only; NO provider keys here)
# Engine endpoint the shell connects to (overrides capsule.engine.endpoint):
NEXUS_ENGINE_ENDPOINT=ws://127.0.0.1:47900/engine
# Web dev only:
VITE_NEXUS_ENGINE_ENDPOINT=ws://127.0.0.1:47900/engine
# Which shell variant to launch (next | classic | gaze-voice | vision-gestures | nate-kb | eye-contact):
EIG_NEXUS_SHELL=next
